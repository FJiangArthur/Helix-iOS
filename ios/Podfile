# Define global platform for iOS 15.0+ (required for JIT compilation compatibility)
platform :ios, '15.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

def ios_project_path
  runner_project = File.expand_path('Runner.xcodeproj', __dir__)
  return runner_project if File.exist?(runner_project)

  candidates = Dir.glob(File.join(__dir__, '*.xcodeproj')).sort
  raise "No Xcode project found in #{__dir__}" if candidates.empty?

  candidates.first
end

def ios_target_names(project_path)
  require 'xcodeproj'

  project = Xcodeproj::Project.open(project_path)
  app_target = project.targets.find do |target|
    target.respond_to?(:product_type) &&
      target.product_type == 'com.apple.product-type.application'
  end
  raise "No iOS application target found in #{project_path}" if app_target.nil?

  test_target = project.targets.find do |target|
    target.respond_to?(:product_type) &&
      target.product_type == 'com.apple.product-type.bundle.unit-test'
  end

  [app_target.name, test_target&.name]
end

ios_project = ios_project_path
ios_project_name = File.basename(ios_project, '.xcodeproj')
ios_app_target_name, ios_test_target_name = ios_target_names(ios_project)

project ios_project_name, {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target ios_app_target_name do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  if ios_test_target_name
    target ios_test_target_name do
      inherit! :search_paths
    end
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)

    target.build_configurations.each do |config|
      # Fix iOS deployment target version
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
      
      # Permission handler macros
      config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= [
        '$(inherited)',

        ## dart: PermissionGroup.microphone
        'PERMISSION_MICROPHONE=1',
      ]
    end
  end
end
