default_platform(:ios)

PROJECT_DIR = File.expand_path("../..", __dir__)
BUNDLE_ID = "com.artjiang.helix"
PROJECT_NAME = "Helix"
IPA_NAME = "Even Companion"
API_KEY = "334J623VNU"
API_ISSUER = "201a71fb-11b4-406e-b857-5908f129d99e"

platform :ios do
  # ─── Helpers ─────────────────────────────────────────────────────────

  def run_security_gate
    Dir.chdir(PROJECT_DIR) do
      sh("bash", "scripts/security_gate.sh", "--repo")
    end
  end

  def flutter_build_ipa(build_number)
    Dir.chdir(PROJECT_DIR) do
      run_security_gate
      sh("flutter", "build", "ipa", "--release",
         "--dart-define=HELIX_FORCE_SANITIZED_LOGS=true",
         "--build-number=#{build_number}",
         "--export-options-plist=ios/fastlane/ExportOptions.plist")
    end
  end

  def ipa_path
    "#{PROJECT_DIR}/build/ios/ipa/#{IPA_NAME}.ipa"
  end

  def upload_ipa
    sh("xcrun", "altool", "--upload-app", "--type", "ios",
       "-f", ipa_path,
       "--apiKey", API_KEY, "--apiIssuer", API_ISSUER)
  end

  # ─── TestFlight ────────────────────────────────────────────────────

  desc "Build Flutter app and upload to TestFlight"
  lane :testflight_release do
    build_number = Time.now.strftime("%Y%m%d%H%M")
    flutter_build_ipa(build_number)
    upload_ipa
    UI.success("Uploaded #{PROJECT_NAME} (#{build_number}) to App Store Connect / TestFlight")
  end

  # ─── App Store Release ─────────────────────────────────────────────

  desc "Build Flutter app and submit to App Store Connect"
  lane :release do
    build_number = Time.now.strftime("%Y%m%d%H%M")
    flutter_build_ipa(build_number)
    upload_ipa
    UI.success("Uploaded #{PROJECT_NAME} (#{build_number}) to App Store Connect")
  end

  # ─── Full Pipeline: TestFlight + App Store ─────────────────────────

  desc "Build once, upload to both TestFlight and App Store Connect"
  lane :ship do
    build_number = Time.now.strftime("%Y%m%d%H%M")
    flutter_build_ipa(build_number)
    upload_ipa
    UI.success("Shipped #{PROJECT_NAME} (#{build_number}) to TestFlight + App Store Connect")
  end
end
