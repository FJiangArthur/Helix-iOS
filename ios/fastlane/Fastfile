default_platform(:ios)

PROJECT_DIR = File.expand_path("../..", __dir__)
BUNDLE_ID = "com.artjiang.helix"
PROJECT_NAME = "Helix"
IPA_NAME = "Even Companion"
XCARCHIVE_PATH = "#{PROJECT_DIR}/build/ios/archive/#{IPA_NAME}.xcarchive"
IPA_DIR = "#{PROJECT_DIR}/build/ios/ipa"
API_KEY_PATH = "#{__dir__}/api_key.json"

platform :ios do
  # ─── Helpers ─────────────────────────────────────────────────────────

  def run_security_gate
    Dir.chdir(PROJECT_DIR) do
      sh("bash", "scripts/security_gate.sh", "--repo")
    end
  end

  def asc_api_key
    app_store_connect_api_key(
      key_id: "334J623VNU",
      issuer_id: "201a71fb-11b4-406e-b857-5908f129d99e",
      key_filepath: File.expand_path("~/.appstoreconnect/admin-AuthKey_334J623VNU.p8"),
      in_house: false,
    )
  end

  def flutter_archive(build_number)
    Dir.chdir(PROJECT_DIR) do
      run_security_gate
      # Archive only — skip the export step that fails without profiles.
      # Fastlane handles export + signing via the API key below.
      sh("flutter", "build", "ios", "--release",
         "--dart-define=HELIX_FORCE_SANITIZED_LOGS=true",
         "--build-number=#{build_number}",
         "--no-codesign")
      sh("xcodebuild", "-workspace", "ios/Runner.xcworkspace",
         "-scheme", "Runner",
         "-configuration", "Release",
         "-archivePath", XCARCHIVE_PATH,
         "DEVELOPMENT_TEAM=4SA9UFLZMT",
         "-allowProvisioningUpdates",
         "-authenticationKeyPath", File.expand_path("~/.appstoreconnect/admin-AuthKey_334J623VNU.p8"),
         "-authenticationKeyID", "334J623VNU",
         "-authenticationKeyIssuerID", "201a71fb-11b4-406e-b857-5908f129d99e",
         "archive")
    end
  end

  def export_and_upload(api_key)
    # Use build_app's export_xcargs to pass provisioning updates auth
    # so the liveactivity extension profile gets auto-created.
    build_app(
      workspace: "#{PROJECT_DIR}/ios/Runner.xcworkspace",
      scheme: "Runner",
      skip_build_archive: true,
      archive_path: XCARCHIVE_PATH,
      export_method: "app-store",
      export_team_id: "4SA9UFLZMT",
      output_directory: IPA_DIR,
      output_name: "#{IPA_NAME}.ipa",
      export_options: {
        signingStyle: "automatic",
        uploadSymbols: true,
      },
      export_xcargs: "-allowProvisioningUpdates " \
                     "-authenticationKeyPath #{File.expand_path("~/.appstoreconnect/admin-AuthKey_334J623VNU.p8")} " \
                     "-authenticationKeyID 334J623VNU " \
                     "-authenticationKeyIssuerID 201a71fb-11b4-406e-b857-5908f129d99e",
    )
    upload_to_testflight(
      api_key: api_key,
      ipa: "#{IPA_DIR}/#{IPA_NAME}.ipa",
      skip_waiting_for_build_processing: true,
    )
  end

  # ─── Upload only (archive + IPA already built) ──────────────────

  desc "Upload an existing IPA to TestFlight (skip build)"
  lane :upload_only do
    api_key = asc_api_key
    ipa = "#{IPA_DIR}/#{IPA_NAME}.ipa"
    UI.user_error!("IPA not found at #{ipa}") unless File.exist?(ipa)
    upload_to_testflight(
      api_key: api_key,
      ipa: ipa,
      skip_waiting_for_build_processing: true,
    )
    UI.success("Uploaded #{ipa} to TestFlight")
  end

  # ─── TestFlight ────────────────────────────────────────────────────

  desc "Build Flutter app and upload to TestFlight"
  lane :testflight_release do
    build_number = Time.now.strftime("%Y%m%d%H%M")
    api_key = asc_api_key
    flutter_archive(build_number)
    export_and_upload(api_key)
    UI.success("Uploaded #{PROJECT_NAME} (#{build_number}) to TestFlight")
  end

  # ─── App Store Release ─────────────────────────────────────────────

  desc "Build Flutter app and submit to App Store Connect"
  lane :release do
    build_number = Time.now.strftime("%Y%m%d%H%M")
    api_key = asc_api_key
    flutter_archive(build_number)
    export_and_upload(api_key)
    UI.success("Uploaded #{PROJECT_NAME} (#{build_number}) to App Store Connect")
  end

  # ─── Full Pipeline ─────────────────────────────────────────────────

  desc "Build once, upload to TestFlight"
  lane :ship do
    build_number = Time.now.strftime("%Y%m%d%H%M")
    api_key = asc_api_key
    flutter_archive(build_number)
    export_and_upload(api_key)
    UI.success("Shipped #{PROJECT_NAME} (#{build_number}) to TestFlight")
  end
end
