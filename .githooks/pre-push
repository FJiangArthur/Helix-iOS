#!/usr/bin/env bash
set -euo pipefail

needs_main_gate=0
while read -r _local_ref _local_sha remote_ref _remote_sha; do
  if [[ "$remote_ref" == "refs/heads/main" ]]; then
    needs_main_gate=1
  fi
done

if [[ "$needs_main_gate" == "1" ]]; then
  HELIX_COMMIT_GATE_FORCE=1 bash scripts/run_commit_gate.sh
else
  bash scripts/security_gate.sh --repo
fi
