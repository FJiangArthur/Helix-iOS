{
  "permissions": {
    "allow": [
      "Skill(ralph-loop:ralph-loop)",
      "Bash(git:*)",
      "Bash(xcrun simctl:*)",
      "Bash(xcodebuild:*)",
      "Bash(grep:*)",
      "WebSearch",
      "Bash(xcrun devicectl:*)",
      "Bash(swift build:*)",
      "Bash(swift test:*)",
      "Bash(chmod:*)",
      "Bash(bash scripts/run_gate.sh)",
      "Bash(bash scripts/run_native_swift_gate.sh)",
      "Bash(gem list:*)",
      "Bash(bundle install:*)",
      "Bash(bundle exec:*)",
      "Bash(xcrun altool:*)",
      "Bash(echo \"EXIT CODE: $?\")"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/helix_sim_validation_hook.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
